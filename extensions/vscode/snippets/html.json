{
  "Component: Button": {
    "name": "Component: Button",
    "prefix": "btn",
    "body": ["<button class=\"btn ${1|filled,tonal,outline,elevated,text|}\">$2</button>$0"],
    "description": "Standard triggers for actions. Use .filled by default for primary actions."
  },
  "Component: Toggle Button": {
    "name": "Component: Toggle Button",
    "prefix": "toggle-btn",
    "body": [
      "<div class=\"toggle-btn ${1|filled,tonal,outline,elevated|}\">",
      "  <input class=\"input\" type=\"${2|checkbox,radio|}\" id=\"${3:id_name}\" />",
      "  <label class=\"label\" for=\"$3\">$4</label>",
      "</div>$0"
    ],
    "description": "Used for selection states. These wrap standard input types to maintain accessibility."
  },
  "Component: Icon Button": {
    "name": "Component: Icon Button",
    "prefix": "icon-btn",
    "body": [
      "<button class=\"icon-btn ${1|filled,tonal,outline,standard|}\" aria-label=\"${2:Favorite}\">",
      "  <span class=\"icon\" aria-hidden=\"true\">${3:icon_name}</span>",
      "</button>$0"
    ],
    "description": "Compact actions represented by an icon. Always include an aria-label."
  },
  "Component: Toggle Icon Button": {
    "name": "Component: Toggle Icon Button",
    "prefix": "toggle-icon-btn",
    "body": [
      "<div class=\"toggle-icon-btn ${1|filled,tonal,outline,standard|}\">",
      "  <input class=\"input\" type=\"${2|checkbox,radio|}\" aria-label=\"${3:Label}\" id=\"${4:id_name}\" />",
      "  <label class=\"label\" for=\"$4\">",
      "    <span class=\"icon\" aria-hidden=\"true\">${5:icon_name}</span>",
      "  </label>",
      "</div>$0"
    ],
    "description": "Visual toggles for states such as bookmarks or 'favorite' status."
  },
  "Component: Standard Button Group": {
    "name": "Component: Standard Button Group",
    "prefix": "standard-btn-group",
    "body": ["<div class=\"standard-btn-group $1\" role=\"group\" aria-label=\"${2:Group Name}\">", "  $0", "</div>"],
    "description": "Groups related buttons together with a consistent gap."
  },
  "Component: Connected Button Group": {
    "name": "Component: Connected Button Group",
    "prefix": "connected-btn-group",
    "body": ["<div class=\"connected-btn-group $1\" role=\"group\" aria-label=\"${2:Group Name}\">", "  $0", "</div>"],
    "description": "A group of connected buttons that stretch to fill the container size."
  },
  "Component: Switch": {
    "name": "Component: Switch",
    "prefix": "switch",
    "body": ["<input class=\"switch $1\" type=\"checkbox\" role=\"switch\" aria-label=\"${2:Toggle setting}\" />$0"],
    "description": "Switches toggle the state of a single setting on or off."
  },
